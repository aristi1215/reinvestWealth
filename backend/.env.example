# --- Server ---
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# --- Supabase (optional) ---
# Leave blank to run with the in-memory store + rich seed data.
# When both are set, the app will use Supabase as its source of truth.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Gemini (optional) ---
# Leave blank to run analyses with mock results based on the seed data.
# When set, real calls hit Google Gemini with rate-limit + JSON safety nets.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Scraping (optional) ---
# Set to "true" to actually run Playwright. Default is mock-mode which
# generates synthetic new reviews to demo the live job pipeline.
ENABLE_PLAYWRIGHT=false

# Set to "true" to register the weekly cron jobs (Sun 02:00 scrape,
# Sun 04:00 analysis, Mon 06:00 digest).
ENABLE_SCHEDULER=false
