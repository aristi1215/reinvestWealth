{
  "name": "reinvestwealth",
  "private": true,
  "version": "1.0.0",
  "description": "ReinvestWealth monorepo",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently -n frontend,backend -c cyan,magenta \"npm run dev -w frontend\" \"npm run dev -w backend\"",
    "dev:frontend": "npm run dev -w frontend",
    "dev:backend": "npm run dev -w backend",
    "build": "npm run build -w backend && npm run build -w frontend",
    "build:frontend": "npm run build -w frontend",
    "build:backend": "npm run build -w backend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
